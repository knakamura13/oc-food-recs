{
	"name": "oc-food-recs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test:pipeline": "python3 -m unittest tests/test_reddit_pipeline.py",
		"pipeline:init:thread-01": "python3 scripts/reddit_pipeline.py init-thread --html tests/fixtures/thread-01.html",
		"pipeline:init:thread-02": "python3 scripts/reddit_pipeline.py init-thread --html tests/fixtures/thread-02.html",
		"pipeline:build:thread-01": "python3 scripts/reddit_pipeline.py build-thread --thread orangecounty-1sb0qo7",
		"pipeline:build:thread-02": "python3 scripts/reddit_pipeline.py build-thread --thread orangecounty-1slszch",
		"pipeline:publish": "python3 scripts/reddit_pipeline.py publish"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6",
		"@types/node": "^25.6.0",
		"playwright": "^1.59.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"fuse.js": "^7.3.0",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3"
	}
}
